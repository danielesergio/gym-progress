{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebTaskList",
  "description": "Lista di feature e task logici per la creazione/miglioramento del sito web fitness, prodotta da gym-web-analyst. Non contiene percorsi di file o dettagli implementativi.",
  "type": "object",
  "required": ["meta", "features"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["data", "project", "goal", "sommario"],
      "additionalProperties": false,
      "properties": {
        "data":             { "type": "string", "description": "Data di generazione YYYY-MM-DD" },
        "project":          { "type": "string" },
        "goal":             { "type": "string", "description": "Obiettivo di questa analisi" },
        "sommario":         { "type": "string" },
        "features_totali":  { "type": "integer", "minimum": 0 },
        "tasks_totali":     { "type": "integer", "minimum": 0 }
      }
    },
    "features": {
      "type": "array",
      "description": "Feature raggruppate per area funzionale, ordinate per priority (1=massima)",
      "items": {
        "type": "object",
        "required": ["name", "priority", "tasks"],
        "additionalProperties": false,
        "properties": {
          "name":        { "type": "string" },
          "priority":    { "type": "integer", "minimum": 1 },
          "description": { "type": "string" },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "title", "description", "inputs", "outputs", "acceptance_criteria", "dependencies"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Identificatore univoco kebab-case, es. weight-chart, dashboard-layout"
                },
                "type": {
                  "type": "string",
                  "enum": ["layout", "component", "page", "data", "navigation", "ux", "bugfix"],
                  "description": "Tipo di artefatto logico"
                },
                "title": {
                  "type": "string",
                  "description": "Titolo breve (max 80 caratteri)"
                },
                "description": {
                  "type": "string",
                  "description": "Descrizione funzionale: cosa deve fare/mostrare questo task. Nessun riferimento a file o tecnologie."
                },
                "inputs": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Nomi logici dei dati o componenti consumati (es. measurements_data, MainLayout)"
                },
                "outputs": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Nomi logici degli artefatti prodotti (es. WeightChart, DashboardPage)",
                  "minItems": 1
                },
                "acceptance_criteria": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Criteri verificabili guardando il sito nel browser, non leggendo il codice",
                  "minItems": 1
                },
                "dependencies": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "ID dei task che devono essere completati prima di questo"
                },
                "notes": {
                  "type": "string",
                  "description": "Osservazioni sui dati disponibili, vincoli o casi limite trovati durante l'analisi"
                }
              }
            }
          }
        }
      }
    }
  }
}
